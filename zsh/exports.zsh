# Personal environment exports (add PATH, JAVA_HOME, etc. here)
export JAVA_HOME=/Library/Java/JavaVirtualMachines/temurin-17.jdk/Contents/Home
export PATH="$HOME/.local/bin:$PATH"

# Anthropic
export ANTHROPIC_BASE_URL=https://api.ai.it.cornell.edu/
export ANTHROPIC_MODEL=anthropic.claude-4.6-sonnet
export ANTHROPIC_SMALL_FAST_MODEL=anthropic.claude-4.5-haiku
